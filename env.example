# ==========================================
# CONFIGURACIÓN DE RENDER - M3U EDITOR PRO
# ==========================================

# Puerto del servidor (Render asigna automáticamente)
PORT=3000

# ==========================================
# NEON DATABASE (OBLIGATORIO)
# ==========================================
# Obtén tu URL de conexión en:
# https://console.neon.tech/ > Tu Proyecto > Connection Details
# Formato: postgres://username:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://tu_usuario:tu_password@host.neon.tech/dbname?sslmode=require

# ==========================================
# PIN DE ACCESO (OBLIGATORIO)
# ==========================================
# PIN de 6 dígitos para acceder a la aplicación
# Valor por defecto si no se define: 198823
APP_PIN=198823

# ==========================================
# INSTRUCCIONES PARA RENDER
# ==========================================
#
# 1. Crea un proyecto en https://dashboard.render.com/
# 2. Crea un Web Service con los siguientes datos:
#    - Name: m3u-editor
#    - Environment: Node
#    - Build Command: npm install
#    - Start Command: npm start
#
# 3. En la sección "Environment Variables" agrega:
#    - DATABASE_URL: Tu URL de Neon (ver arriba)
#    - APP_PIN: 198823 (o el PIN que desees)
#    - PORT: 3000
#
# 4. Despliega y Enjoy!
#
# ==========================================
